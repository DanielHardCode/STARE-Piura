# STARE Piura — Variables de entorno

# ─── Data Provider ───────────────────────────────────────────────────────────
# Opciones: "mock" | "supabase" | "supabase_laravel"
# "mock"             → 100% offline con datos Faker.
# "supabase"         → operaciones directas a Supabase (lectura/escritura).
# "supabase_laravel" → lecturas desde Supabase, escrituras vía API Laravel.
VITE_DATA_PROVIDER="mock"

# ─── Supabase (requerido en modo supabase o supabase_laravel) ────────────────
VITE_SUPABASE_URL="https://TU_PROYECTO.supabase.co"
VITE_SUPABASE_ANON_KEY="TU_SUPABASE_ANON_KEY"

# ─── Laravel API (requerido solo si VITE_DATA_PROVIDER=supabase_laravel) ─────
VITE_LARAVEL_API_URL="http://localhost:8000/api"

# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="STARE Piura"
VITE_APP_VERSION="1.0.0"
